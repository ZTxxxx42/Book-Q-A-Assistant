# ===== 抽取 LLM：远程 GLM-4.7（实体抽取 / 关键词抽取，OpenAI 兼容）=====
LLM_BINDING=openai
LLM_API_KEY=sk-YOUR_GLM_KEY
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=glm-4.7
LLM_STREAMING=true
# GLM 并发保守 2 避免 429（6 次 retry 兜底）
LLM_MODEL_MAX_ASYNC=2

# ===== 答复 LLM：本地 Ollama Qwen2.5-7B（仅最终答复生成，OpenAI 兼容）=====
QUERY_LLM_API_KEY=ollama
QUERY_LLM_BASE_URL=http://localhost:21434/v1
QUERY_LLM_MODEL=qwen2.5:7b-instruct
QUERY_LLM_STREAMING=true
# Ollama 默认 OLLAMA_NUM_PARALLEL=1；调高需同步设 Ollama env
QUERY_LLM_MODEL_MAX_ASYNC=1

# ===== Embedding + Rerank：SiliconFlow（硅基流动）API =====
EMBEDDING_BINDING=openai
EMBEDDING_API_KEY=sk-YOUR_SILICONFLOW_KEY
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

RERANK_API_KEY=sk-YOUR_SILICONFLOW_KEY
RERANK_BASE_URL=https://api.siliconflow.cn/v1
RERANK_MODEL=BAAI/bge-reranker-v2-m3
ENABLE_RERANK=true

# 单次 embedding 请求的批量大小（SiliconFlow 上限约 64）
EMBEDDING_BATCH_NUM=32

# ===== 向量库：Qdrant（Docker 容器，docker compose up -d 启动）=====
QDRANT_URL=http://localhost:16333
# QDRANT_API_KEY=   # 本地 Docker 无需 key，留空即可
# 真 cosine 相似度（Qdrant Distance.COSINE，score >= threshold 保留），0.2 为合理下限
COSINE_THRESHOLD=0.2

# ===== 查询 / 检索质量 =====
TOP_K=40
CHUNK_TOP_K=12
# rerank 分数门槛（LightRAG 直接读此 env）；0.0=不过滤，0.3=过滤低相关 chunk
MIN_RERANK_SCORE=0.3
INCLUDE_REFERENCES=true
RESPONSE_TYPE=Single Paragraph

# ===== Query 容错护栏（A1 硬拒答）=====
# 预探测命中 chunk 数下限；不足则硬拒答（不调答复 LLM）
MIN_HIT_COUNT=1
# 硬拒答 rerank 分数门槛（与 MIN_RERANK_SCORE 对齐）
HARD_REFUSE_THRESHOLD=0.3
HARD_REFUSE_ANSWER=知识库中未找到足够信息回答此问题。

# ===== LLM 调用鲁棒性（A2）=====
LLM_TIMEOUT=60
QUERY_LLM_TIMEOUT=120
STREAM_FIRST_TOKEN_TIMEOUT=60
# SSE 心跳间隔（秒，A4）
STREAM_HEARTBEAT_INTERVAL=15
# CORS 允许来源（逗号分隔；留空则不启用 CORS；前后端同源时无需配置）
# 含 "*" 时自动关闭 credentials（CORS 规范禁止通配源带凭证）；生产建议列显式来源
CORS_ORIGINS=

# ===== 输入校验（A0）=====
MAX_QUESTION_LENGTH=2000
MAX_BOOK_NAME_LENGTH=200
MAX_HISTORY_TURNS=10

# ===== 并发硬化（B0/B1/B2）=====
# LightRAG 实例池容量（按 workspace 缓存）
RAG_POOL_SIZE=5
# 全局并发闸（initialize_share_data；让 max_async 跨请求生效）
GLOBAL_EXTRACT_CONCURRENCY=2
GLOBAL_KEYWORD_CONCURRENCY=2
GLOBAL_QUERY_CONCURRENCY=1
GLOBAL_EMBEDDING_CONCURRENCY=4
GLOBAL_RERANK_CONCURRENCY=4
# HTTP 入口最大并发；ingest 最大并发（单机 GPU 一次一本）
MAX_CONCURRENT_REQUESTS=8
MAX_CONCURRENT_INGEST=1
# /query 整体超时（秒）
QUERY_OVERALL_TIMEOUT=180
# 完成任务 TTL（秒）
TASK_TTL=3600

# ===== Neo4j =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=bookgraph123

# ===== 存储 / 分块 =====
WORKING_DIR=./rag_storage
CHUNK_SIZE=1200
CHUNK_OVERLAP=100
LANGUAGE=chinese
