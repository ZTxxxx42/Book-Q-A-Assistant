# ===== LLM：本地 Ollama（Qwen2.5-7B-Instruct，OpenAI 兼容）=====
LLM_BINDING=openai
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b-instruct
LLM_STREAMING=true
# Ollama 默认 OLLAMA_NUM_PARALLEL=1，故并发设 1；调高需同步设 Ollama env
LLM_MODEL_MAX_ASYNC=1

# ===== Embedding + Rerank：SiliconFlow（硅基流动）API =====
EMBEDDING_BINDING=openai
EMBEDDING_API_KEY=sk-YOUR_SILICONFLOW_KEY
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

RERANK_API_KEY=sk-YOUR_SILICONFLOW_KEY
RERANK_BASE_URL=https://api.siliconflow.cn/v1
RERANK_MODEL=BAAI/bge-reranker-v2-m3
ENABLE_RERANK=true

# 单次 embedding 请求的批量大小（SiliconFlow 上限约 64）
EMBEDDING_BATCH_NUM=32

# ===== 向量库：Qdrant（Docker 容器，docker compose up -d 启动）=====
QDRANT_URL=http://localhost:16333
# QDRANT_API_KEY=   # 本地 Docker 无需 key，留空即可
# 真 cosine 相似度（Qdrant Distance.COSINE，score >= threshold 保留），0.2 为合理下限
COSINE_THRESHOLD=0.2

# ===== Neo4j =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=bookgraph123

# ===== 存储 / 分块 =====
WORKING_DIR=./rag_storage
CHUNK_SIZE=1200
CHUNK_OVERLAP=100
LANGUAGE=chinese
